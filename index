        var PRESET_VERSION = 161;

        function loadSignatures() {
            // 强制使用预置数据，确保签名始终显示
            var stored = localStorage.getItem('rose_signatures_v');
            if (stored === String(PRESET_VERSION)) {
                try {
                    var data = JSON.parse(localStorage.getItem('rose_signatures'));
                    if (data && data.length >= PRESET_VERSION) return data;
                } catch(e) {}
            }
            // 初始化或升级：用预置数据
            localStorage.setItem('rose_signatures', JSON.stringify(PRESET_SIGNATURES));
            localStorage.setItem('rose_signatures_v', String(PRESET_VERSION));
            return PRESET_SIGNATURES;
        }

        function saveSignatures(signatures) {
            localStorage.setItem('rose_signatures', JSON.stringify(signatures));
        }

        function addSignature(name, message) {
            var signatures = loadSignatures();
            var now = new Date();
            var dateStr = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0') + '-' + String(now.getDate()).padStart(2,'0');
            signatures.unshift({ name: name, message: message, date: dateStr });
            saveSignatures(signatures);
            return signatures;
        }

        function renderSignatures(signatures) {
            var grid = document.getElementById('signatures-grid');
            var count = document.getElementById('signature-count');
            count.textContent = signatures.length;

            if (signatures.length === 0) {
                grid.innerHTML = '<div class="empty">还没有签名，快来第一个！</div>';
                return;
            }

            var html = '';
            for (var i = 0; i < signatures.length; i++) {
                var sig = signatures[i];
                var bgColor = colors[i % colors.length];
                var nameColor = nameColors[i % nameColors.length];
                html += '<div class="signature-bubble" style="background:' + bgColor + ';border-color:' + nameColor + '">';
                html += '<div class="signature-name" style="color:' + nameColor + '">' + sig.name + '</div>';
                if (sig.message) html += '<div class="signature-message">' + sig.message + '</div>';
                html += '</div>';
            }
            grid.innerHTML = html;
        }

        document.getElementById('signature-form').addEventListener('submit', function(e) {
            e.preventDefault();
            var name = document.getElementById('name').value.trim();
            var message = document.getElementById('message').value.trim();
            if (!name) return;
            var signatures = addSignature(name, message);
            document.getElementById('name').value = '';
            document.getElementById('message').value = '';
            renderSignatures(signatures);
        });

        // 初始化渲染
        renderSignatures(loadSignatures());
    </script>
